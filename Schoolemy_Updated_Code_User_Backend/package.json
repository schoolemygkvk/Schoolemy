{
  "name": "schoolemy-node-user-backend",
  "version": "1.0.0",
  "description": "Backend API for Schoolemy User System — built with Express, MongoDB, and ES6 modules.",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "deploy": "node build-lambda.js",
    "lint": "eslint . --fix",
    "test": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --runInBand --coverage",
    "test:watch": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:debug": "cross-env NODE_ENV=test DEBUG=true NODE_OPTIONS=--experimental-vm-modules jest --runInBand --verbose",
    "test:unit": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --runInBand tests/unit/**/*.test.js --coverage",
    "test:integration": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --runInBand tests/integration/**/*.test.js --coverage",
    "test:e2e": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --runInBand tests/e2e/**/*.test.js",
    "test:security": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --runInBand tests/security/**/*.test.js",
    "test:coverage": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --runInBand --coverage --coverageReporters=text-summary",
    "test:coverage:html": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --runInBand --coverage && open coverage/index.html",
    "test:ci": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --ci --coverage --maxWorkers=2",
    "test:report": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --runInBand --coverage --coverage JunitReporter",
    "audit:check": "npm audit",
    "audit:fix": "npm audit fix && npm audit fix --force",
    "audit:report": "npm audit --json > audit-report.json",
    "security:audit": "npm audit --audit-level=moderate",
    "snyk:test": "snyk test --severity-threshold=high",
    "snyk:monitor": "snyk monitor",
    "snyk:fix": "snyk fix",
    "licenses:check": "license-checker --onlyunknown && license-checker --prohibitOnly GPL,AGPL,SSPL"
  },
  "keywords": [
    "nodejs",
    "express",
    "mongodb",
    "backend",
    "api",
    "schoolemy",
    "user system"
  ],
  "author": "Schoolemy Team",
  "license": "ISC",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1031.0",
    "@aws-sdk/credential-providers": "^3.1031.0",
    "@aws-sdk/lib-storage": "^3.1031.0",
    "@aws-sdk/s3-request-presigner": "^3.1038.0",
    "archiver": "^7.0.1",
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.19.0",
    "express-validator": "^7.0.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.19.3",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.10",
    "pdfkit": "^0.17.2",
    "prom-client": "^15.1.0",
    "sanitize-html": "^2.11.0",
    "serverless-http": "^4.0.0",
    "sharp": "^0.34.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "twilio": "^5.10.5",
    "which": "^6.0.1",
    "winston": "^3.14.2",
    "winston-daily-rotate-file": "^4.7.1",
    "xss": "^1.0.14"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.28.5",
    "@jest/globals": "^30.3.0",
    "babel-jest": "^30.3.0",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.1",
    "jest": "^30.3.0",
    "mongodb-memory-server": "^10.3.0",
    "nodemon": "^3.1.11",
    "supertest": "^7.2.2"
  }
}
