# ==========================================================================
# PRODUCTION REGISTRATION FLOW - ENVIRONMENT VARIABLES
# ==========================================================================
# Copy this file to .env and fill in your values
# Never commit actual .env file to version control
# ==========================================================================

# ==========================================================================
# SERVER & ENVIRONMENT
# ==========================================================================
NODE_ENV=production
PORT=8000
HOST=0.0.0.0

# ==========================================================================
# DATABASE
# ==========================================================================
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/schoolemy

# ==========================================================================
# SECURITY & JWT TOKENS
# ==========================================================================
JWT_SECRET=your-secret-key-min-32-characters-long
# Access token JWT + cookie lifetime (e.g. 4h, 60m). Default in code is 4h.
ACCESS_TOKEN_EXPIRY=4h
REFRESH_TOKEN_EXPIRY=30d

# ==========================================================================
# FRONTEND
# ==========================================================================
FRONTEND_URL=https://yourdomain.com
ALLOWED_ORIGINS=https://yourdomain.com

# ==========================================================================
# EMAIL SERVICE
# ==========================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_EMAIL=noreply@schoolemy.com

# ==========================================================================
# SMS SERVICE
# ==========================================================================
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1234567890

# ==========================================================================
# RATE LIMITING
# ==========================================================================
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_OTP_WINDOW_MS=600000
RATE_LIMIT_OTP_MAX=3

# ==========================================================================
# ACCOUNT CLEANUP JOB
# ==========================================================================
ACCOUNT_CLEANUP_ENABLED=true
ACCOUNT_CLEANUP_SCHEDULE=0 2 * * *
ACCOUNT_CLEANUP_DAYS=30

# ==========================================================================
# REDIS (Optional)
# ==========================================================================
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379

# ==========================================================================
# LOGGING
# ==========================================================================
LOG_LEVEL=info
LOG_FORMAT=json

# ==========================================================================
# FILE UPLOAD & AWS S3 (Profile Images)
# ==========================================================================
MAX_PROFILE_PICTURE_SIZE_MB=5
PROFILE_PICTURE_WIDTH=512
PROFILE_PICTURE_HEIGHT=512
PROFILE_PICTURE_QUALITY=70

# ==========================================================================
# AWS S3 CONFIGURATION (Profile Image Storage)
# ==========================================================================
USE_AWS_S3=true
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=schoolemy-profile-images
AWS_CLOUDFRONT_URL=https://d1234.cloudfront.net

# ==========================================================================
# SECURITY
# ==========================================================================
ENABLE_HELMET=true
ENABLE_CSRF_PROTECTION=true
ENABLE_RATE_LIMITING=true
ENABLE_CORS=true

# ==========================================================================
# DEBUGGING (Development Only)
# ==========================================================================
DEBUG=false
REQUEST_LOGGING=true
