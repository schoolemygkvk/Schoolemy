# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
PORT=5000

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# MongoDB connection string (with credentials)
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/database-name

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================
# Gmail address for sending emails
EMAIL_ADMIN=your-email@gmail.com
# Gmail App Password (NOT your regular password)
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_PASS=xxxx xxxx xxxx xxxx

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# Support Contact Email (used in frontend)
SUPPORT_EMAIL=support@schoolemy.com

# =============================================================================
# JWT CONFIGURATION
# =============================================================================
# Secret key for JWT token signing (use a strong random string)
JWT_SECRET=your-secret-jwt-key-here

# =============================================================================
# TWILIO CONFIGURATION
# =============================================================================
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token-here

# =============================================================================
# AWS S3 CONFIGURATION
# =============================================================================
# AWS IAM User Access Key ID
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS IAM User Secret Access Key
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# AWS Region
AWS_REGION=ap-south-1

# =============================================================================
# S3 BUCKET NAMES
# =============================================================================
AWS_S3_BUCKET_SCHOOLEMY=courses-audio-bucket-schoolemy
AWS_S3_BUCKET_TUTOR=schoolemy-course-audio-bucket-tutors
AWS_S3_STAFF_BUCKET=admin-staff-profile-images

# =============================================================================
# CDN CONFIGURATION (OPTIONAL)
# =============================================================================
# CloudFront distribution URL for media S3 buckets
# Leave blank if CloudFront is not yet deployed
# Format: https://d123abc.cloudfront.net
CLOUDFRONT_MEDIA_URL=

# =============================================================================
# TUTOR SYSTEM CONFIGURATION
# =============================================================================
GST_RATE=18
# Master key for super admin operations (use a strong random string)
SUPER_ADMIN_KEY=your-master-key-here

# =============================================================================
# GOOGLE MEET CONFIGURATION
# =============================================================================
# Google Meet links for different subjects
PHYSICS_MEET_LINK=https://meet.google.com/your-meet-link
CHEMISTRY_MEET_LINK=https://meet.google.com/your-meet-link
MATHS_MEET_LINK=https://meet.google.com/your-meet-link

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================
# Frontend URL for email links and redirects
FRONTEND_URL=https://schoolemyadmin.schoolemy.com

# =============================================================================
# API STAGE
# =============================================================================
# Used for Lambda API Gateway stage
API_STAGE=dev

# =============================================================================
# NODE ENVIRONMENT
# =============================================================================
NODE_ENV=development
