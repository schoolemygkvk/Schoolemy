# # =============================================================================
# # ENVIRONMENT VARIABLE REFERENCE
# # =============================================================================
# # Copy this file to .env.development or .env.production and fill in values.
# # Never commit .env.development or .env.production to version control.
# # =============================================================================

# # Backend API base URL (no trailing slash) - REQUIRED
# # Development:
# #   - Local Express: http://localhost:5000
# #   - Remote API Gateway (avoid duplicate CORS in browser): /lambda-dev and set REACT_APP_DEV_API_PROXY_TARGET
# #     in .env.development (see src/setupProxy.js)
# # Production:  https://<your-api-gateway-id>.execute-api.<region>.amazonaws.com/dev
# REACT_APP_API_URL=http://localhost:5000

# # AWS S3 Upload API URL - REQUIRED
# # Development: http://localhost:5000
# # Production:  https://<your-api-gateway-id>.execute-api.<region>.amazonaws.com/dev
# REACT_APP_AWS_API_URL=http://localhost:5000

# # Support/Contact Email Address
# REACT_APP_SUPPORT_EMAIL=support@schoolemy.com

# # Socket.IO server URL (leave blank to disable WebSocket features)
# # Example: wss://api.schoolemy.com
# REACT_APP_SOCKET_URL=

# # CloudFront CDN URL for media assets (optional)
# # Leave blank if CloudFront is not yet deployed
# # Format: https://d123abc.cloudfront.net
# REACT_APP_CDN_URL=

# # Set to true to enable verbose debug logging in the browser console
# REACT_APP_DEBUG=false

# # Set to false to skip generating source maps (recommended for production)
# GENERATE_SOURCEMAP=false

# # =============================================================================
# # NOTES
# # =============================================================================
# # For production deployment:
# # 1. Set REACT_APP_API_URL to your Lambda API Gateway endpoint
# # 2. Set REACT_APP_AWS_API_URL to your Lambda API Gateway endpoint
# # 3. Set REACT_APP_SUPPORT_EMAIL to your actual support email
# # 4. Ensure HTTPS is used in production
# # 5. Never commit .env files with real credentials to version control
