{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^7.1.1",
    "@mui/material": "^7.1.1",
    "@react-pdf-viewer/core": "^3.12.0",
    "@react-pdf-viewer/default-layout": "^3.12.0",
    "aos": "^2.3.4",
    "axios": "^1.10.0",
    "cashfree-pg-sdk-javascript": "^2.0.8",
    "chart.js": "^4.4.9",
    "cra-template": "1.2.0",
    "dompurify": "^3.0.9",
    "framer-motion": "^11.16.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.1.0",
    "lucide-react": "^0.474.0",
    "react": "^19.0.0",
    "react-awesome-reveal": "^4.3.1",
    "react-chartjs-2": "^5.3.0",
    "react-circular-progressbar": "^2.2.0",
    "react-countup": "^6.5.3",
    "react-dom": "^19.0.0",
    "react-icons": "^5.5.0",
    "react-modal": "^3.16.3",
    "react-pdf": "^9.2.1",
    "react-player": "^2.16.0",
    "react-router-dom": "^7.6.2",
    "react-scripts": "^5.0.1",
    "react-toastify": "^11.0.5",
    "styled-components": "^6.1.15",
    "swiper": "^12.1.3",
    "web-vitals": "^4.2.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "test:coverage": "react-scripts test --coverage --watchAll=false",
    "eject": "react-scripts eject"
  },
  "jest": {
    "collectCoverageFrom": [
      "src/utils/**/*.js",
      "src/pages/Course/utils/**/*.js",
      "src/Context/**/*.js",
      "src/service/eventapi.js",
      "src/service/meetPaymentApi.js",
      "src/service/coursePlayerStateService.js",
      "src/service/apiErrorHandler.js",
      "!src/utils/examStateManager.js",
      "!src/utils/profileImageUrl.js",
      "!src/utils/wishlistStorage.js",
      "!src/utils/paymentValidator.js",
      "!src/utils/emailValidator.js",
      "!src/utils/safeLessonMediaUrl.js",
      "!src/service/meetPaymentApi.js",
      "!src/utils/storageValidator.js",
      "!src/**/*.styles.js",
      "!src/**/__tests__/**",
      "!src/**/__mocks__/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    },
    "moduleNameMapper": {
      "\\.(css|less|scss|sass)$": "identity-obj-proxy",
      "\\.(gif|ttf|eot|svg|png|jpg|jpeg)$": "<rootDir>/src/__mocks__/fileMock.js",
      "^react-router-dom$": "<rootDir>/node_modules/react-router-dom/dist/index.js",
      "^react-router$": "<rootDir>/node_modules/react-router/dist/development/index.js",
      "^react-router/dom$": "<rootDir>/node_modules/react-router/dist/development/dom-export.js"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(axios|@cashfree)/)"
    ]
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/plugin-transform-class-properties": "^7.28.6",
    "@babel/plugin-transform-object-rest-spread": "^7.28.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "identity-obj-proxy": "^3.0.0"
  }
}
